{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/tauri.conf.schema.json",
  "productName": "Ferrlock",
  "version": "0.1.3",
  "identifier": "com.ferrlock.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": []
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/OliverMarcusson/ferrlock/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU0QTQ0RkYwMjA2RUNFNApSV1RrN0FZQy8wUktEbnYvdWMxV3lmOG5rU21UWXBHY3JIb0dUL2ZXSXdRNUNsakorcTBmSVhQbgo=",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
